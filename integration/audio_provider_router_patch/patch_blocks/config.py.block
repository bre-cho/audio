# Add inside Settings
minimax_api_key: str | None = os.getenv("MINIMAX_API_KEY")
minimax_base_url: str | None = os.getenv("MINIMAX_BASE_URL")
audio_preview_upload_to_object_storage: bool = _get_bool("AUDIO_PREVIEW_UPLOAD_TO_OBJECT_STORAGE", True)
audio_preview_dir: str = os.getenv("AUDIO_PREVIEW_DIR", "/app/storage/audio_previews")
audio_provider_default: str = os.getenv("AUDIO_PROVIDER_DEFAULT", "elevenlabs")
