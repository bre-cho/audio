{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ArtifactContract",
  "type": "object",
  "required": [
    "artifact_id",
    "artifact_type",
    "mime_type",
    "size_bytes",
    "checksum",
    "created_at",
    "source_job_id",
    "project_id",
    "input_hash",
    "provider",
    "template_version",
    "runtime_version"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_type": {
      "type": "string"
    },
    "path": {
      "type": [
        "string",
        "null"
      ]
    },
    "url": {
      "type": [
        "string",
        "null"
      ]
    },
    "mime_type": {
      "type": "string"
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 1
    },
    "checksum": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "source_job_id": {
      "type": "string",
      "minLength": 1
    },
    "project_id": {
      "type": "string",
      "minLength": 1
    },
    "input_hash": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "template_version": {
      "type": "string",
      "minLength": 1
    },
    "runtime_version": {
      "type": "string",
      "minLength": 1
    }
  },
  "anyOf": [
    {
      "required": [
        "path"
      ]
    },
    {
      "required": [
        "url"
      ]
    }
  ]
}