{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DecisionContract",
  "type": "object",
  "required": [
    "decision_id",
    "trigger_type",
    "scenarios_considered",
    "selected_action",
    "score_breakdown",
    "selected_reason",
    "confidence_score",
    "policy_version",
    "decision_actor",
    "execution_status",
    "outcome_tracking_id"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "trigger_type": {
      "type": "string"
    },
    "scenarios_considered": {
      "type": "array",
      "minItems": 1
    },
    "selected_action": {
      "type": "string"
    },
    "rejected_actions": {
      "type": "array"
    },
    "score_breakdown": {
      "type": "object"
    },
    "selected_reason": {
      "type": "string",
      "minLength": 1
    },
    "confidence_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "policy_version": {
      "type": "string"
    },
    "decision_actor": {
      "enum": [
        "system",
        "ci",
        "operator"
      ]
    },
    "execution_status": {
      "enum": [
        "pending",
        "executed",
        "failed"
      ]
    },
    "outcome_tracking_id": {
      "type": "string"
    }
  }
}