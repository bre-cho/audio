# Application Configuration
APP_ENV=dev
APP_NAME=audio-ai-system
CI=true

# Database & Cache
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/audio_ai
REDIS_URL=redis://redis:6379/0

# Storage
S3_ENDPOINT_URL=http://minio:9000
S3_BUCKET=audio-assets
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
ARTIFACT_ROOT=/artifacts

# Audio Providers
DEFAULT_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=sk-test-elevenlabs-dummy-key-do-not-use
MINIMAX_API_KEY=sk-test-minimax-dummy-key-do-not-use

# Docker Compose
DOCKER_COMPOSE_BIN=docker compose

# Backend Services
BACKEND_SCHEMA_BOOTSTRAP=metadata-create-all

# Health Check & Monitoring
MONITOR_BASE_URL=http://localhost:8000
BASE_URL=http://localhost:8000
API_SERVICE=api
WORKER_SERVICE=worker

# E2E Testing Configuration
AUTH_ENABLED=0
AUDIO_E2E_AUTH_ENABLED=0
AUTH_EMAIL=test@localhost
AUTH_PASSWORD=test@localhost
TEST_USER_EMAIL=test@localhost
TEST_USER_PASSWORD=test@localhost
AUDIO_E2E_EMAIL=test@localhost
AUDIO_E2E_PASSWORD=test@localhost
SAMPLE_PATH=backend/data/audio/test_sample.mp3
AUDIO_SYNTHETIC_SAMPLE_TEXT=This is a synthetic preview check for the audio platform.
AUDIO_HEALTH_CHECK_TIMEOUT_SECONDS=30

# Staging/Canary Configuration
STAGING_BASE_URL=http://localhost:8000
STAGING_ALERTMANAGER_URL=http://localhost:9093
CANARY_BASE_URL=http://localhost:8000/canary
CANARY_HEALTH_URL=http://localhost:8000/api/v1/audio/health
CANARY_PERCENT=50
PROD_BASE_URL=http://localhost:8000

# Deployment Configuration
DEPLOY_COMMAND=docker compose pull && docker compose up -d api worker
ROLLBACK_COMMAND=docker compose down && docker compose up -d api worker
CANARY_DEPLOY_COMMAND=docker compose up -d api worker
SHIFT_TRAFFIC_COMMAND=echo 'Traffic shifted to $CANARY_PERCENT%'
FETCH_STABLE_COMMAND=echo 'stable'

# Slack & Alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/PLACEHOLDER/CHANGE_ME/PLACEHOLDER
SLACK_CHANNEL=#alerts-audio

# Monitoring & Observability
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3001
ALERTMANAGER_URL=http://localhost:9093
ALERTMANAGER_API_URL=http://alertmanager:9093

# Chaos Testing
SCENARIOS=worker_kill,provider_fail
KEEP_BROKEN_STATE=0
AUDIO_TEST_AUTH_ENABLED=0
CHAOS_SAMPLE_PATH=./test_sample.mp3

# Skip options for CI
SKIP_STACK_UP=0
VERIFY_RUNTIME=1

# Polling Configuration
PREVIEW_POLL_ATTEMPTS=40
NARRATION_POLL_ATTEMPTS=12
RUN_NARRATION_E2E=0

# Report Directories
REPORT_DIR=.verify_audio_e2e
